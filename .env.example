# ============================================================
# POS-AI SaaS - Environment Variables
# Copy file ini ke .env dan isi sesuai kebutuhan
# ============================================================

# --- Database ---
DB_USER=posai_user
DB_PASSWORD=ganti_password_db_yang_kuat
DB_NAME=posai
DB_PORT=3307          # Port MySQL yang di-expose ke host

# --- Security ---
SECRET_KEY=ganti-ini-dengan-random-string-minimum-32-karakter-yang-aman
SUPERADMIN_PASSWORD=ganti_password_superadmin

# --- Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Debug (jangan aktifkan di production) ---
DEBUG=false

# ============================================================
# CATATAN:
# - Setiap tenant setup API key AI mereka sendiri via Settings UI
# - Superadmin dibuat otomatis saat pertama deploy (username: superadmin)
# - Docs API tersedia di: http://localhost:8000/docs
# ============================================================
